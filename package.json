{
  "name": "@luutuankiet/mcp-proxy-shim",
  "version": "1.3.5",
  "description": "MCP proxy shim for mcpproxy-go — transforms call_tool_* args_json:string to native args:object. Supports stdio and HTTP Streamable transports.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-proxy-shim": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js serve",
    "dev": "npx tsx src/index.ts",
    "dev:http": "npx tsx src/index.ts serve",
    "test:daemon": "node test/daemon-e2e.mjs",
    "test:issue7": "node test/issue-7-multiline-args.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcpproxy-go",
    "proxy",
    "shim",
    "stdio",
    "http"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luutuankiet/mcp-proxy-shim.git"
  },
  "homepage": "https://github.com/luutuankiet/mcp-proxy-shim#readme",
  "bugs": {
    "url": "https://github.com/luutuankiet/mcp-proxy-shim/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "undici": "^7.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
